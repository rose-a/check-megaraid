#!/usr/bin/env python3
"""MegaRAID health check for Proxmox / storcli.

Default (--check): notify only when unhealthy.
--monthly: always notify with full storcli dumps and HEALTHY/UNHEALTHY title.

Delivery uses Proxmox VE's notification system (PVE::Notify, template type
"simple") so mail is built like other PVE/PBS notifications.
"""

from __future__ import annotations

import argparse
import os
import re
import socket
import subprocess
import sys
from pathlib import Path

OK_PD_STATES = frozenset({"Onln", "DHS", "GHS"})

# Unsupported but common hook into libpve-notify-perl (see PVE forum).
PVE_NOTIFY_PERL = r"""
use strict;
use warnings;
use PVE::Notify;

my $sev = $ENV{LEVEL} // die "LEVEL missing\n";
my $title = $ENV{TITLE} // "";
my $message = $ENV{MESSAGE} // "";

my $common = eval { PVE::Notify::common_template_data() } // {};
my $data = {
    %$common,
    title   => $title,
    message => $message,
};
my $fields = { origin => "check-megaraid" };

PVE::Notify::notify($sev, "simple", $data, $fields);
"""


def hostname_short() -> str:
    try:
        return socket.gethostname().split(".", 1)[0] or "unknown"
    except OSError:
        return "unknown"


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8", errors="replace").replace("\r", "")


def run_storcli(storcli: str, *args: str) -> str:
    try:
        proc = subprocess.run(
            [storcli, *args],
            check=False,
            capture_output=True,
            text=True,
            errors="replace",
        )
    except FileNotFoundError as exc:
        raise SystemExit(f"storcli not found: {storcli}") from exc
    return (proc.stdout or "").replace("\r", "")


def load_show(storcli: str, show_file: Path | None) -> str:
    if show_file is not None:
        return read_text(show_file)
    return run_storcli(storcli, "show")


def load_c0(storcli: str, c0_file: Path | None) -> str:
    if c0_file is not None:
        return read_text(c0_file)
    return run_storcli(storcli, "/c0", "show")


def field_after_eq(text: str, key: str) -> str | None:
    for line in text.splitlines():
        if line.startswith(f"{key} = "):
            return line.split(" = ", 1)[1].strip()
    return None


def section_lines(text: str, start: str, stop_prefixes: tuple[str, ...]) -> list[str]:
    lines = text.splitlines()
    out: list[str] = []
    active = False
    for line in lines:
        if not active:
            if line.startswith(start):
                active = True
            continue
        if any(line.startswith(p) for p in stop_prefixes):
            break
        if line.startswith("----") or not line.strip():
            continue
        out.append(line)
    return out


def parse_show(text: str, findings: list[str]) -> None:
    status = field_after_eq(text, "Status")
    if status and status != "Success":
        findings.append(f"storcli show: Status={status} (expected Success)")

    controllers = field_after_eq(text, "Number of Controllers")
    try:
        nctl = int(controllers) if controllers is not None else 0
    except ValueError:
        nctl = 0
    if nctl < 1:
        findings.append("storcli show: no controllers found")
        return

    # Ctl Model Ports PDs DGs DNOpt VDs VNOpt BBU sPR DS EHS ASOs Hlth
    overview_line = None
    for line in section_lines(text, "System Overview", ("Ctl=",)):
        parts = line.split()
        if len(parts) >= 14 and parts[0].isdigit():
            overview_line = parts
            break

    if overview_line is None:
        findings.append("storcli show: could not parse System Overview")
        return

    dnopt = overview_line[5]
    vnopt = overview_line[7]
    hlth = overview_line[-1]

    if hlth != "Opt":
        findings.append(f"Controller Hlth={hlth} (expected Opt)")
    if dnopt != "0":
        findings.append(f"DNOpt={dnopt} (arrays not optimal)")
    if vnopt != "0":
        findings.append(f"VNOpt={vnopt} (VDs not optimal)")


def parse_c0(text: str, findings: list[str]) -> None:
    status = field_after_eq(text, "Status")
    if status and status != "Success":
        findings.append(f"storcli /c0 show: Status={status} (expected Success)")

    vd_count = 0
    for line in section_lines(
        text, "VD LIST", ("VD=", "Physical Drives", "TOPOLOGY", "PD LIST", "Enclosures")
    ):
        parts = line.split()
        if len(parts) < 3 or not re.fullmatch(r"\d+/\d+", parts[0]):
            continue
        vd_count += 1
        dgvd, typ, state = parts[0], parts[1], parts[2]
        if state != "Optl":
            findings.append(f"VD {dgvd} ({typ}) State={state} (expected Optl)")

    pd_count = 0
    for line in section_lines(
        text, "PD LIST", ("EID=", "Enclosures", "Enclosure LIST")
    ):
        parts = line.split()
        if len(parts) < 3:
            continue
        eidslt, did, state = parts[0], parts[1], parts[2]
        if not re.fullmatch(r"\d+:\d+", eidslt) or not did.isdigit():
            continue
        pd_count += 1
        if state not in OK_PD_STATES:
            findings.append(f"PD {eidslt} DID={did} State={state}")

    for line in section_lines(text, "Enclosure LIST", ("EID=",)):
        parts = line.split()
        if len(parts) < 2 or not parts[0].isdigit():
            continue
        eid, estate = parts[0], parts[1]
        if estate != "OK":
            findings.append(f"Enclosure EID={eid} State={estate} (expected OK)")

    if vd_count == 0:
        findings.append("storcli /c0 show: no virtual drives parsed")
    if pd_count == 0:
        findings.append("storcli /c0 show: no physical drives parsed")


def findings_text(findings: list[str]) -> str:
    if not findings:
        return "No issues detected."
    return "\n".join(f"- {f}" for f in findings)


def excerpt_show(text: str) -> str:
    lines = text.splitlines()
    out: list[str] = []
    active = False
    for line in lines:
        if line.startswith("System Overview"):
            active = True
        if active:
            out.append(line)
            if line.startswith("Hlth="):
                break
    return "\n".join(out)


def excerpt_c0(text: str) -> str:
    lines = text.splitlines()
    out: list[str] = []
    active = False
    for line in lines:
        if line.startswith("VD LIST"):
            active = True
        if active:
            out.append(line)
            if line.startswith("Enclosures"):
                break
    return "\n".join(out)


def build_alert_body(host: str, verdict: str, findings: list[str], show: str, c0: str) -> str:
    return (
        f"MegaRAID check on {host}: {verdict}\n\n"
        f"Findings:\n{findings_text(findings)}\n\n"
        f"---- storcli show (excerpt: System Overview) ----\n"
        f"{excerpt_show(show)}\n\n"
        f"---- storcli /c0 show (VD LIST + PD LIST) ----\n"
        f"{excerpt_c0(c0)}\n"
    )


def build_monthly_body(host: str, verdict: str, findings: list[str], show: str, c0: str) -> str:
    return (
        f"MegaRAID monthly summary on {host}: {verdict}\n\n"
        f"Findings:\n{findings_text(findings)}\n\n"
        f"{'=' * 80}\n"
        f"storcli show\n"
        f"{'=' * 80}\n"
        f"{show.rstrip()}\n\n"
        f"{'=' * 80}\n"
        f"storcli /c0 show\n"
        f"{'=' * 80}\n"
        f"{c0.rstrip()}\n"
    )


def pve_notify(level: str, title: str, message: str, *, dry_run: bool) -> None:
    """Raise a PVE notification (template type 'simple')."""
    if dry_run:
        print(f"=== PVE NOTIFY ===")
        print(f"Severity: {level}")
        print(f"Title: {title}")
        print()
        print(message)
        return

    env = os.environ.copy()
    env["LEVEL"] = level
    env["TITLE"] = title
    env["MESSAGE"] = message

    try:
        proc = subprocess.run(
            ["perl", "-MPVE::Notify", "-e", PVE_NOTIFY_PERL],
            env=env,
            check=False,
            capture_output=True,
            text=True,
            errors="replace",
        )
    except FileNotFoundError as exc:
        raise SystemExit(
            "perl not found; check-megaraid must run on Proxmox VE"
        ) from exc

    if proc.returncode != 0:
        err = (proc.stderr or proc.stdout or "").strip()
        if "PVE/Notify" in err or "Can't locate PVE/Notify.pm" in err:
            raise SystemExit(
                "PVE::Notify not available (install/run on Proxmox VE with "
                f"libpve-notify-perl). Details: {err}"
            )
        raise SystemExit(f"PVE::Notify failed ({proc.returncode}): {err}")


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    p = argparse.ArgumentParser(description="MegaRAID health check via storcli")
    mode = p.add_mutually_exclusive_group()
    mode.add_argument(
        "--check",
        action="store_const",
        const="check",
        dest="mode",
        help="interval check: notify only on problems (default)",
    )
    mode.add_argument(
        "--monthly",
        action="store_const",
        const="monthly",
        dest="mode",
        help="monthly summary: always notify with full dumps + verdict",
    )
    p.set_defaults(mode="check")
    p.add_argument("--show-file", type=Path, help="fixture instead of: storcli show")
    p.add_argument("--c0-file", type=Path, help="fixture instead of: storcli /c0 show")
    p.add_argument(
        "--test",
        action="store_true",
        help="send a test PVE notification and exit",
    )
    p.add_argument(
        "--dry-run",
        action="store_true",
        help="print notification that would be sent; do not notify",
    )
    return p.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv)
    storcli = os.environ.get("CHECK_MEGARAID_STORCLI", "storcli")
    host = hostname_short()

    if args.test:
        pve_notify(
            "info",
            f"MegaRAID {host}: TEST",
            f"Test message from check-megaraid on {host}.\n",
            dry_run=args.dry_run,
        )
        return 0

    show = load_show(storcli, args.show_file)
    c0 = load_c0(storcli, args.c0_file)

    findings: list[str] = []
    parse_show(show, findings)
    parse_c0(c0, findings)

    healthy = not findings
    verdict = "HEALTHY" if healthy else "UNHEALTHY"

    if args.mode == "check":
        if not healthy:
            pve_notify(
                "error",
                f"MegaRAID {host}: ALERT",
                build_alert_body(host, verdict, findings, show, c0),
                dry_run=args.dry_run,
            )
    elif args.mode == "monthly":
        pve_notify(
            "info" if healthy else "error",
            f"MegaRAID {host}: {verdict}",
            build_monthly_body(host, verdict, findings, show, c0),
            dry_run=args.dry_run,
        )

    return 0 if healthy else 1


if __name__ == "__main__":
    sys.exit(main())
